---
import Button from "./Button.astro";
import Email from "../icons/Email.astro";
import Linkedin from "../icons/Linkedin.astro";
---

<section class="container-main py-32" id="contact">
  <div
    class="max-w-4xl mx-auto rounded-[2rem] bg-gradient-to-br from-slate-900 to-background-dark border border-slate-800 px-8 py-12 md:p-16 text-center"
  >
    <h2 class="text-4xl md:text-5xl font-black text-slate-100 mb-8">
      Ready to unlock your data's potential?
    </h2>
    <p class="text-slate-400 text-lg mb-12">
      I'm currently looking for new opportunities in Data Analysis and Business
      Intelligence. Let's build something insightful together.
    </p>
    <div class="flex flex-wrap justify-center gap-6">
      <Button
        text="Email Me"
        color="primary"
        link="mailto:hello@vallipriya.com"
        blank={false}
        icon={Email}
      />
      <Button
        text="LinkedIn"
        color="tertiary"
        link="https://www.linkedin.com/in/vallipriyan/"
        black={true}
        icon={Linkedin}
      />
    </div>
  </div>
</section>
