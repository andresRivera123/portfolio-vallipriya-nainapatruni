---
interface ButtonProps {
  text: string;
  color: "primary" | "secondary";
  link: string;
  blank: boolean;
}

const { text, color = "primary", link, blank } = Astro.props;
---

<a
  href={link}
  target={blank === true ? "_blank" : "_self"}
  class={`max-w-max inline-flex items-center px-7 py-2 text-sm font-medium rounded-full text-pretty ${color === "primary" ? "bg-[var(--color-primary)] border-gray-200[var(--color-primary)]g-4 focus:outline-none focus:ring-gray-100 hover:scale-105 transition-transform" : ""} ${color === "secondary" ? "bg-white border-gray-200  hover:bg-gray-100 focus:z-10 focus:ring-4 focus:outline-none focus:ring-gray-100 hover:scale-105 transition-transform" : ""}`}
  >{text}</a
>
