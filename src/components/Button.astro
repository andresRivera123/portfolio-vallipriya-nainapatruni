---
interface ButtonProps {
  text: string
  color?: "primary" | "secondary"
  link: string
  blank?: boolean
}

const { text, color = "primary", link, blank = false } = Astro.props as ButtonProps

const baseStyles =
  "max-w-max inline-flex items-center text-base px-7 py-3 font-bold rounded-xl text-pretty transition-transform hover:scale-105"

const variants = {
  primary:
    "bg-[var(--color-primary)] text-white",
  secondary:
    "bg-slate-900 border border-slate-800 text-slate-100"
}
---

<a
  href={link}
  target={blank ? "_blank" : "_self"}
  class={`${baseStyles} ${variants[color]}`}
>
  {text}
</a>