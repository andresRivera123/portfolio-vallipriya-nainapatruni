---
import Button from "../components/Button.astro";
---

<section class="container-main pt-24 pb-32">
  <div class="max-w-7xl mx-auto flex flex-col items-center text-center">
    <div
      class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary/10 border border-primary/20 text-primary text-xs font-bold mb-8 uppercase tracking-widest"
    >
      Available for Opportunities
    </div>
    <h1
      class="text-5xl md:text-7xl font-black text-slate-100 leading-[1.1] tracking-tight mb-8"
    >
      Vallipriya Nainapatruni<br />
      <span
        class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-blue-400"
        >Data Analytics</span
      >
    </h1>
    <p
      class="max-w-2xl text-lg md:text-xl text-slate-400 font-light leading-relaxed mb-12"
    >
      Transforming complex datasets into actionable narratives. Specializing in
      advanced statistical modeling and interactive visualization to drive
      business intelligence.
    </p>
    <div class="flex flex-col sm:flex-row gap-4 items-center">
      <Button text="View Portfolio" color="primary" link="/" blank={false} />
      <Button text="Let's Talk" color="secondary" link="/" blank={false} />
    </div>
  </div>
</section>
